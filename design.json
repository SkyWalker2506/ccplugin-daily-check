{
  "cds_version": "1.0",
  "name": "ccplugin-daily-check",
  "type": "plugin",
  "input_patterns": [
    {
      "type": "slash_command",
      "commands": [
        "/check-daily"
      ]
    },
    {
      "type": "auto_trigger",
      "keywords": [
        "daily check",
        "health check",
        "sistem kontrol"
      ],
      "confirm": false,
      "cooldown": 86400
    }
  ],
  "output_patterns": [
    {
      "type": "terminal_text",
      "max_lines": 20
    },
    {
      "type": "cache_file",
      "path": "~/.cache/claude/daily-check/",
      "ttl_seconds": 86400
    }
  ],
  "lifecycle": {
    "preflight": {
      "required_tools": [
        "jq",
        "curl"
      ],
      "required_secrets": [],
      "required_mcp": []
    }
  },
  "error_handling": {
    "retry_network": true,
    "max_retries": 2,
    "fallback": "partial report with available checks"
  }
}
